# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get these from https://neon.tech → your project → Connection Details
# Use the "pooled" connection string for DATABASE_URL (serverless functions)
# Use the "direct" connection string for DIRECT_URL (prisma migrate)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# ── OAuth providers (optional) ────────────────────────────────────────────────
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
